{
  "name": "@traefik-labs/faency",
  "description": "Traefik Labs design system",
  "version": "1.0.0-semantic-release",
  "license": "Apache-2.0",
  "keywords": [
    "traefiklabs",
    "ui",
    "design system",
    "react",
    "radix-ui",
    "a11y"
  ],
  "main": "dist/index.js",
  "type": "module",
  "modulesDir": "dist",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "types": "dist/index.d.ts",
  "homepage": "https://traefik.github.io/faency/",
  "repository": "https://github.com/traefik/faency",
  "bugs": {
    "url": "https://github.com/traefik/faency/issues"
  },
  "scripts": {
    "prettier": "prettier --write .",
    "build": "vite build",
    "lint": "eslint \"./components/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"./components/**/*.{ts,tsx}\"",
    "release": "yarn build && np",
    "storybook": "cross-env NODE_OPTIONS=--openssl-legacy-provider storybook dev -p 6006 -h localhost",
    "storybook-docs": "storybook dev --docs",
    "build-storybook": "cross-env NODE_OPTIONS=--openssl-legacy-provider storybook build",
    "test": "jest --watch",
    "test:ci": "jest --ci --silent",
    "prepare": "husky install",
    "pre-commit": "lint-staged"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@floating-ui/react": "0.27.19",
    "@radix-ui/colors": "2.1.0",
    "@radix-ui/react-accessible-icon": "1.1.8",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-icons": "1.3.2",
    "@radix-ui/react-id": "1.1.1",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-portal": "1.1.10",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@radix-ui/react-use-layout-effect": "1.1.1",
    "@radix-ui/react-visually-hidden": "1.2.4",
    "@rehookify/datepicker": "6.6.8",
    "@stitches/react": "1.2.8",
    "@vanilla-extract/css": "1.20.1",
    "@vanilla-extract/dynamic": "2.1.5",
    "@vanilla-extract/recipes": "0.5.7",
    "date-fns": "4.1.0",
    "prism-react-renderer": "2.4.1",
    "prismjs": "1.30.0",
    "tinycolor2": "1.6.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-transform-react-pure-annotations": "7.27.1",
    "@babel/preset-env": "7.29.2",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@eslint/js": "9.39.4",
    "@mdx-js/react": "^2.1.5",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-links": "10.3.5",
    "@storybook/builder-vite": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@types/jest": "30.0.0",
    "@types/jest-axe": "^3.5.3",
    "@types/node": "^24.10.1",
    "@types/prismjs": "1.26.6",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/tinycolor2": "^1.4.3",
    "@vanilla-extract/vite-plugin": "5.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "@vueless/storybook-dark-mode": "10.0.7",
    "babel-jest": "30.3.0",
    "babel-loader": "8.4.1",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "cross-env": "^7.0.3",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-storybook": "10.3.5",
    "globals": "^15.8.0",
    "husky": "^8.0.0",
    "jest": "30.3.0",
    "jest-axe": "^6.0.0",
    "jest-environment-jsdom": "30.3.0",
    "lint-staged": "13.1.0",
    "np": "^8.0.4",
    "patch-package": "^8.0.0",
    "prettier": "3.8.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "semantic-release": "25.0.3",
    "storybook": "10.3.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.58.1",
    "vite": "7.1.11",
    "vite-plugin-dts": "^4.5.4",
    "webpack": "5.104.1"
  },
  "resolutions": {
    "baseline-browser-mapping@^2.10.12": "2.10.17",
    "electron-to-chromium@^1.5.328": "1.5.334"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,css,md}": "prettier --write"
  },
  "release": {
    "branches": [
      "master",
      "next"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits"
        }
      ],
      [
        "@semantic-release/npm",
        {
          "provenance": true
        }
      ],
      "@semantic-release/github"
    ]
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
